# all variables are optional, with defaults for local development
AZURE_AI_FOUNDRY_CONNECTION_STRING=
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-5-mini
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Auth mode: "default_credential" (default) uses Azure CLI / managed identity
#             "passthrough" uses bearer token from MCP client
AUTH_MODE=default_credential
# AZURE_TENANT_ID=       # optional, for DefaultAzureCredential
# AZURE_BEARER_TOKEN=    # only needed when AUTH_MODE=passthrough (for dev)
